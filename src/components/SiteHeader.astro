---
interface Props {
  /** Si se pasa, muestra un enlace de regreso en lugar del menu. */
  backHref?: string;
  backLabel?: string;
}
const { backHref, backLabel = 'Volver al inicio' } = Astro.props;
---

<header class="site-header">
  <div class="container bar">
    <a class="brand" href="/">
      <span class="brand__sign" aria-hidden="true">
        <span class="dot dot--red"></span>
        <span class="dot dot--amber"></span>
        <span class="dot dot--green"></span>
      </span>
      <span class="brand__text">
        <strong>Taller B1</strong>
        <small>Examen teorico de conduccion · Colombia</small>
      </span>
    </a>

    {
      backHref ? (
        <a class="back" href={backHref}>
          <span aria-hidden="true">&larr;</span> {backLabel}
        </a>
      ) : (
        <a class="back" href="#modos">Empezar &darr;</a>
      )
    }
  </div>
  <div class="road-line" role="presentation"></div>
</header>

<style>
  .site-header {
    background: var(--asphalt);
    color: #fff;
    position: sticky;
    top: 0;
    z-index: 30;
  }
  .bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding-block: 0.85rem;
  }
  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    color: #fff;
  }
  .brand:hover {
    text-decoration: none;
  }
  .brand__sign {
    display: inline-flex;
    flex-direction: column;
    gap: 3px;
    padding: 5px;
    background: #11151a;
    border-radius: 8px;
  }
  .dot {
    width: 11px;
    height: 11px;
    border-radius: 50%;
  }
  .dot--red {
    background: var(--signal-red);
  }
  .dot--amber {
    background: var(--signal-amber);
  }
  .dot--green {
    background: var(--signal-green);
  }
  .brand__text {
    display: flex;
    flex-direction: column;
    line-height: 1.1;
  }
  .brand__text strong {
    font-family: var(--font-display);
    font-size: 1.2rem;
    letter-spacing: 0.01em;
  }
  .brand__text small {
    color: #b8bec6;
    font-size: 0.74rem;
  }
  .back {
    color: #fff;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 0.95rem;
    /* Objetivo tactil de al menos 44px de alto. */
    padding: 0.62rem 1rem;
    border: 1.5px solid rgba(255, 255, 255, 0.25);
    border-radius: 8px;
  }
  .back:hover {
    background: rgba(255, 255, 255, 0.1);
    text-decoration: none;
  }
  @media (max-width: 520px) {
    .brand__text small {
      display: none;
    }
  }
</style>
