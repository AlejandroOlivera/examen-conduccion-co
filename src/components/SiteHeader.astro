---
interface Props {
  /** Si se pasa, muestra un enlace de regreso en lugar del menu. */
  backHref?: string;
  backLabel?: string;
}
const { backHref, backLabel = 'Volver al inicio' } = Astro.props;
---

<header class="site-header">
  <div class="container bar">
    <a class="brand" href="/">
      <span class="brand__sign" aria-hidden="true">
        <span class="dot dot--red"></span>
        <span class="dot dot--amber"></span>
        <span class="dot dot--green"></span>
      </span>
      <span class="brand__text">
        <strong>Taller B1</strong>
        <small>Examen teorico de conduccion · Colombia</small>
      </span>
    </a>

    <div class="actions">
      <button
        type="button"
        class="theme-toggle"
        data-theme-toggle
        aria-pressed="false"
        aria-label="Cambiar entre modo claro y oscuro"
        title="Cambiar tema"
      >
        <svg
          class="icon icon--sun"
          viewBox="0 0 24 24"
          aria-hidden="true"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
        >
          <circle cx="12" cy="12" r="4"></circle>
          <path
            d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4"
          ></path>
        </svg>
        <svg class="icon icon--moon" viewBox="0 0 24 24" aria-hidden="true" fill="currentColor">
          <path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z"></path>
        </svg>
      </button>

      <a class="back" href="/cuenta" data-auth-login>Entrar</a>
      <div class="auth-user" data-auth-user hidden>
        <span class="auth-user__name" data-auth-name></span>
        <a class="back auth-user__panel" href="/panel">Mi panel</a>
        <button type="button" class="back auth-user__logout" data-auth-logout>Salir</button>
      </div>

      {
        backHref ? (
          <a class="back" href={backHref}>
            <span aria-hidden="true">&larr;</span> {backLabel}
          </a>
        ) : (
          <a class="back" href="#modos">
            Empezar &darr;
          </a>
        )
      }
    </div>
  </div>
  <div class="road-line" role="presentation"></div>
</header>

<style>
  .site-header {
    background: var(--asphalt);
    color: #fff;
    position: sticky;
    top: 0;
    z-index: 30;
    /* Con viewport-fit=cover, el asfalto cubre la zona del notch y el contenido
       se mantiene por debajo de la barra de estado. */
    padding-top: env(safe-area-inset-top, 0px);
  }
  .bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding-block: 0.85rem;
  }
  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    color: #fff;
  }
  .brand:hover {
    text-decoration: none;
  }
  .brand__sign {
    display: inline-flex;
    flex-direction: column;
    gap: 3px;
    padding: 5px;
    background: #11151a;
    border-radius: 8px;
  }
  .dot {
    width: 11px;
    height: 11px;
    border-radius: 50%;
  }
  .dot--red {
    background: var(--signal-red);
  }
  .dot--amber {
    background: var(--signal-amber);
  }
  .dot--green {
    background: var(--signal-green);
  }
  .brand__text {
    display: flex;
    flex-direction: column;
    line-height: 1.1;
  }
  .brand__text strong {
    font-family: var(--font-display);
    font-size: 1.2rem;
    letter-spacing: 0.01em;
  }
  .brand__text small {
    color: #b8bec6;
    font-size: 0.74rem;
  }
  .actions {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }
  .theme-toggle {
    display: inline-grid;
    place-items: center;
    width: 42px;
    height: 42px;
    flex: none;
    color: #fff;
    background: transparent;
    border: 1.5px solid rgba(255, 255, 255, 0.25);
    border-radius: 8px;
    cursor: pointer;
    transition:
      background 0.16s var(--ease-out),
      border-color 0.16s var(--ease-out);
  }
  .theme-toggle:hover {
    background: rgba(255, 255, 255, 0.1);
  }
  .theme-toggle .icon {
    width: 20px;
    height: 20px;
    grid-area: 1 / 1;
    transition:
      opacity 0.2s var(--ease-out),
      transform 0.3s var(--ease-out);
  }
  /* Por defecto (claro) se ve el sol; en oscuro, la luna. */
  .theme-toggle .icon--moon {
    opacity: 0;
    transform: rotate(-90deg) scale(0.6);
  }
  :root[data-theme='dark'] .theme-toggle .icon--sun {
    opacity: 0;
    transform: rotate(90deg) scale(0.6);
  }
  :root[data-theme='dark'] .theme-toggle .icon--moon {
    opacity: 1;
    transform: none;
  }
  .back {
    color: #fff;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 0.95rem;
    /* Objetivo tactil de al menos 44px de alto. */
    padding: 0.62rem 1rem;
    border: 1.5px solid rgba(255, 255, 255, 0.25);
    border-radius: 8px;
  }
  .back:hover {
    background: rgba(255, 255, 255, 0.1);
    text-decoration: none;
  }
  .auth-user {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }
  .auth-user__name {
    color: #fff;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 0.9rem;
    max-width: 12ch;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .auth-user__logout {
    background: transparent;
    cursor: pointer;
  }
  @media (max-width: 520px) {
    .brand__text small {
      display: none;
    }
    .auth-user__name {
      display: none;
    }
  }
</style>

<script>
  import { initHeaderAuth } from '../scripts/auth';
  initHeaderAuth();
</script>
