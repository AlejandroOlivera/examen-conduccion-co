---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
---

<BaseLayout title="Tu panel · Taller B1" noindex={true}>
  <!-- render-blocking auth guard: runs before paint, redirects to /cuenta if no session -->
  <script is:inline src="/panel-guard.js" slot="head"></script>

  <SiteHeader slot="header" backHref="/" backLabel="Todos los temas" />

  <section class="container panel" data-accent="azul">
    <span class="tag">Mi panel</span>
    <h1 id="panel-title" tabindex="-1">Tu progreso</h1>
    <div class="road-line" role="presentation"></div>

    <!-- carro/moto toggle: hidden until dashboard.ts enters data view -->
    <div class="panel__switch" role="group" aria-label="Categoria" data-panel-switch hidden>
      <button type="button" data-panel-cat="carro" aria-pressed="true">Carro</button>
      <button type="button" data-panel-cat="moto" aria-pressed="false">Moto</button>
    </div>

    <div id="panel-root" class="panel__root">
      <!-- dashboard.ts renders here: skeletons -> KPI grid + sections -->
    </div>
  </section>

  <SiteFooter slot="footer" />
</BaseLayout>

<script>
  import { initDashboard } from '../scripts/dashboard';

  // Con ViewTransitions la pagina no se recarga al navegar: montamos en
  // astro:page-load (dispara en la carga inicial y tras cada navegacion) y
  // desmontamos en astro:before-swap para no arrastrar listeners pendientes.
  let teardown: (() => void) | null = null;

  function mount() {
    if (teardown) return; // guard de doble montaje
    const root = document.getElementById('panel-root');
    if (root) teardown = initDashboard(root);
  }

  function unmount() {
    teardown?.();
    teardown = null;
  }

  document.addEventListener('astro:page-load', mount);
  document.addEventListener('astro:before-swap', unmount);
</script>

<style>
  /* Scoped styles for the static shell markup (authored in this .astro file). */
  .panel {
    max-width: 860px;
    padding-block: clamp(2rem, 6vw, 4rem);
  }

  h1 {
    font-size: var(--text-3xl);
    margin: var(--space-3) 0 0;
  }

  .panel .road-line {
    width: 84px;
    margin: var(--space-3) 0 var(--space-4);
  }

  .panel__switch {
    display: inline-flex;
    gap: var(--space-1);
    margin-bottom: var(--space-4);
  }

  .panel__switch button {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: var(--text-sm);
    color: var(--ink-soft);
    background: var(--paper-2);
    border: 1.5px solid var(--line);
    border-radius: 8px;
    padding: var(--space-2) var(--space-3);
    cursor: pointer;
    transition:
      background 0.14s var(--ease-out),
      color 0.14s var(--ease-out);
  }

  .panel__switch button[aria-pressed='true'] {
    background: var(--accent);
    color: #fff;
    border-color: var(--accent);
  }

  .panel__root {
    width: 100%;
  }
</style>

<style is:global>
  /*
   * Global styles for DOM nodes generated at runtime by dashboard.ts.
   * MUST be is:global because Astro-scoped styles never match runtime-created DOM.
   * Mirrors the is:global pattern used by [modo].astro for quiz classes.
   * Classes are prefixed .panel__ to avoid collision with quiz classes.
   * All colors use design tokens so dark mode is free.
   */

  /* KPI grid — 5 cards responsive */
  .panel__kpi-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
    gap: var(--space-3);
    margin-bottom: var(--space-6);
  }

  .panel__kpi-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--space-2);
    padding: var(--space-4);
    text-align: center;
  }

  .panel__kpi-value {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: var(--text-2xl);
    color: var(--accent);
    line-height: 1;
    /* Skeleton placeholder sizing */
    min-height: 2.1rem;
    width: 100%;
  }

  .panel__kpi-label {
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--ink-soft);
    /* Skeleton placeholder sizing */
    min-height: 1rem;
    width: 100%;
  }

  /* Skeleton sizing within KPI cards */
  .panel__kpi-card .skeleton.panel__kpi-value {
    height: 2.1rem;
  }

  .panel__kpi-card .skeleton.panel__kpi-label {
    height: 0.9rem;
    width: 70%;
    margin-inline: auto;
  }
</style>
