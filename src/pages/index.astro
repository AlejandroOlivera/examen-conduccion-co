---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import ModeCard from '../components/ModeCard.astro';
import { modesForCategory } from '../data/modes';
import { questionsForGroups, QUESTIONS } from '../data/questions';
import { DEFAULT_CATEGORY } from '../data/category';

// El hero es de carro (Licencia B1): cuenta solo las preguntas de esa categoria.
const total = QUESTIONS.filter((q) => q.category === DEFAULT_CATEGORY).length;

// Datos estructurados de la home: identidad del sitio (Organization) y el
// sitio web (WebSite), enlazados por @id. URLs absolutas como el canonical.
const orgId = new URL('#org', Astro.site).href;
const homeUrl = new URL('/', Astro.site).href;
const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Organization',
      '@id': orgId,
      name: 'Taller B1',
      url: homeUrl,
      logo: new URL('/og.png', Astro.site).href,
      sameAs: ['https://github.com/AlejandroOlivera'],
    },
    {
      '@type': 'WebSite',
      '@id': new URL('#website', Astro.site).href,
      url: homeUrl,
      name: 'Taller B1',
      description:
        'Taller interactivo para preparar el examen teorico de conduccion (Licencia B1) en Colombia, segun la normativa vigente.',
      inLanguage: 'es-CO',
      publisher: { '@id': orgId },
    },
  ],
};

// Datos de referencia rapida (limites de velocidad — Ley 2251 de 2022).
const speeds = [
  { via: 'Zonas escolares y residenciales', max: '30 km/h' },
  { via: 'Vias urbanas y municipales', max: '50 km/h' },
  { via: 'Vias rurales', max: '80 km/h' },
  { via: 'Carreteras nacionales y departamentales', max: '90 km/h' },
  { via: 'Doble calzada sin pasos peatonales', max: '120 km/h' },
];
---

<BaseLayout title="Taller B1 · Examen teorico de conduccion (Colombia)" jsonLd={jsonLd}>
  <!-- Render-blocking en <head> (anti-FOUC): fija data-categoria en <html>
       antes del paint para mostrar la grilla correcta sin parpadeo. Sin JS,
       el atributo no se fija y ambas grillas quedan visibles (todo navegable). -->
  <script is:inline src="/category.js" slot="head"></script>
  <SiteHeader slot="header" />

  <!-- Hero -->
  <section class="hero">
    <div class="container hero__inner">
      <span class="tag">Licencia B1 · Carro particular</span>
      <h1 class="hero__title">
        Prepara tu <span>examen teorico</span> de conduccion
      </h1>
      <p class="hero__lead">
        Taller interactivo con la estructura oficial del CALE: cuatro grupos tematicos, una seccion
        para carro mecanico y un simulacro cronometrado. Basado en la normativa colombiana vigente.
      </p>
      <div class="hero__cta">
        <a class="btn btn--dark" id="cta-simulacro" href="/examen/carro/simulacro"
          >Hacer el simulacro</a
        >
        <a class="btn btn--ghost" href="#modos">Practicar por temas</a>
      </div>
      <dl class="hero__stats">
        <div><dt>{total}</dt><dd>preguntas con explicacion</dd></div>
        <div><dt>40 / 40</dt><dd>simulacro: preguntas / minutos</dd></div>
        <div><dt>80%</dt><dd>para aprobar</dd></div>
      </dl>
    </div>
  </section>

  <!-- Modos -->
  <section id="modos" class="container section">
    <header class="section__head reveal">
      <h2>Elige un tema para practicar</h2>
      <p>
        Cada bloque te da retroalimentacion inmediata y la justificacion normativa de cada
        respuesta.
      </p>
      <div class="catswitch" role="group" aria-label="Categoria de licencia">
        <button type="button" class="catswitch__btn" data-cat-btn="carro" aria-pressed="true">
          Carro · B1
        </button>
        <button type="button" class="catswitch__btn" data-cat-btn="moto" aria-pressed="false">
          Moto · A2
        </button>
      </div>
    </header>
    <div class="grid" data-cat-grid="carro">
      {
        modesForCategory('carro').map((mode) => (
          <ModeCard mode={mode} count={questionsForGroups(mode.category, mode.groups).length} />
        ))
      }
    </div>
    <div class="grid" data-cat-grid="moto">
      {
        modesForCategory('moto').map((mode) => (
          <ModeCard mode={mode} count={questionsForGroups(mode.category, mode.groups).length} />
        ))
      }
    </div>
  </section>

  <!-- Referencia rapida -->
  <section class="container section">
    <header class="section__head reveal">
      <h2>Antes de empezar: limites de velocidad</h2>
      <p>
        Modificados por la Ley 2251 de 2022 ("Ley Julian Esteban"). Son de las preguntas mas
        frecuentes.
      </p>
    </header>
    <div class="speeds">
      {
        speeds.map((s) => (
          <div class="speed reveal">
            <span class="speed__max">{s.max}</span>
            <span class="speed__via">{s.via}</span>
          </div>
        ))
      }
    </div>
  </section>

  <!-- Recursos -->
  <section class="container section--sm">
    <a class="recursos-link" href="/senales">
      <span class="recursos-link__icon" aria-hidden="true">🚦</span>
      <span class="recursos-link__text">
        <strong>Catalogo de senales de transito</strong>
        <small>Repasa el significado de cada senal antes de practicar</small>
      </span>
      <span class="recursos-link__arrow" aria-hidden="true">&rarr;</span>
    </a>
  </section>

  <SiteFooter slot="footer" />
</BaseLayout>

<style>
  .hero {
    background:
      linear-gradient(180deg, rgba(28, 32, 36, 0) 60%, rgba(28, 32, 36, 0.03)), var(--paper);
    border-bottom: 1px solid var(--line);
  }
  .hero__inner {
    padding-block: clamp(2.5rem, 7vw, 5rem);
  }
  .hero__title {
    font-size: clamp(2.2rem, 7vw, 4.2rem);
    line-height: 0.98;
    margin: 1rem 0;
    max-width: 16ch;
  }
  .hero__title span {
    color: var(--signal-green);
    position: relative;
    white-space: nowrap;
  }
  .hero__title span::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0.06em;
    height: 0.14em;
    background: repeating-linear-gradient(90deg, var(--signal-amber) 0 14px, transparent 14px 24px);
  }
  .hero__lead {
    font-size: clamp(1.05rem, 2.4vw, 1.3rem);
    color: var(--ink-soft);
    max-width: 58ch;
  }
  .hero__cta {
    display: flex;
    gap: 0.8rem;
    flex-wrap: wrap;
    margin-top: 1.6rem;
  }
  .hero__stats {
    display: flex;
    flex-wrap: wrap;
    gap: 2.5rem;
    margin: 2.5rem 0 0;
    padding-top: 1.6rem;
    border-top: 1px dashed var(--line);
  }
  .hero__stats div {
    display: flex;
    flex-direction: column;
  }
  .hero__stats dt {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 2rem;
    color: var(--ink);
    line-height: 1;
  }
  .hero__stats dd {
    margin: 0.3rem 0 0;
    color: var(--ink-soft);
    font-size: 0.9rem;
    max-width: 18ch;
  }

  .section {
    padding-block: clamp(2.5rem, 6vw, 4rem);
  }
  .section__head {
    margin-bottom: 1.8rem;
    max-width: 60ch;
  }
  .section__head h2 {
    font-size: clamp(1.5rem, 4vw, 2.2rem);
  }
  .section__head p {
    color: var(--ink-soft);
    margin: 0.5rem 0 0;
  }

  /* Selector segmentado carro/moto. Sin JS queda en su estado por defecto
     (carro) y la grilla de carro es la visible. */
  .catswitch {
    display: inline-flex;
    margin-top: 1.1rem;
    background: var(--paper-2);
    border: 1px solid var(--line);
    border-radius: 999px;
    padding: 0.25rem;
    gap: 0.25rem;
  }
  .catswitch__btn {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.9rem;
    color: var(--ink-soft);
    background: transparent;
    border: 0;
    border-radius: 999px;
    padding: 0.45rem 1rem;
    cursor: pointer;
    transition:
      background 0.14s ease,
      color 0.14s ease;
  }
  .catswitch__btn[aria-pressed='true'] {
    background: var(--card);
    color: var(--ink);
    box-shadow: var(--shadow);
  }
  .catswitch__btn:hover:not([aria-pressed='true']) {
    color: var(--ink);
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.1rem;
  }
  /* La grilla visible la decide data-categoria en <html>, fijado por
     category.js antes del paint (anti-FOUC). Sin JS el atributo no existe y
     ambas grillas quedan visibles, de modo que toda la home es navegable. */
  :global(html[data-categoria='carro']) .grid[data-cat-grid='moto'],
  :global(html[data-categoria='moto']) .grid[data-cat-grid='carro'] {
    display: none;
  }
  /* El simulacro (ultima tarjeta) es el modo estrella: fila completa
     destacada en vez de quedar huerfano en la rejilla de 3 columnas. */
  @media (min-width: 900px) {
    .grid > :global(.card:last-child) {
      grid-column: 1 / -1;
    }
  }

  .speeds {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 0.9rem;
  }
  .speed {
    background: var(--card);
    border: 1px solid var(--line);
    border-top: 4px solid var(--signal-amber);
    border-radius: var(--radius-sm);
    padding: 1.1rem;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    box-shadow: var(--shadow);
  }
  .speed__max {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 1.7rem;
    color: var(--ink);
  }
  .speed__via {
    color: var(--ink-soft);
    font-size: 0.9rem;
  }

  .section--sm {
    padding-block: clamp(1rem, 3vw, 2rem);
  }
  .recursos-link {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    background: var(--card);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: var(--space-4) var(--space-5);
    text-decoration: none;
    color: var(--ink);
    box-shadow: var(--shadow-sm);
    transition:
      box-shadow var(--dur-fast) var(--ease-out),
      border-color var(--dur-fast) var(--ease-out);
    max-width: 520px;
  }
  .recursos-link:hover {
    box-shadow: var(--shadow);
    border-color: var(--ink-faint);
  }
  .recursos-link__icon {
    font-size: 2rem;
    flex-shrink: 0;
  }
  .recursos-link__text {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    flex: 1;
  }
  .recursos-link__text strong {
    font-family: var(--font-display);
    font-size: var(--text-base);
    font-weight: 700;
  }
  .recursos-link__text small {
    color: var(--ink-soft);
    font-size: var(--text-sm);
  }
  .recursos-link__arrow {
    color: var(--ink-faint);
    font-size: 1.3rem;
    flex-shrink: 0;
  }
</style>
