---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
---

<BaseLayout title="Pagina no encontrada · Taller B1">
  <SiteHeader slot="header" backHref="/" />
  <section class="container wrap">
    <span class="code">404</span>
    <h1>Esa via no existe</h1>
    <p>El tema o la pagina que buscas no esta disponible. Vuelve al inicio para elegir un modo de practica.</p>
    <a class="btn" href="/">Volver al inicio</a>
  </section>
  <SiteFooter slot="footer" />
</BaseLayout>

<style>
  .wrap {
    padding-block: clamp(3rem, 10vw, 7rem);
    text-align: center;
  }
  .code {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: clamp(4rem, 18vw, 9rem);
    color: var(--signal-amber-dark);
    line-height: 1;
  }
  .wrap h1 {
    font-size: clamp(1.6rem, 5vw, 2.6rem);
    margin: 0.5rem 0 0.7rem;
  }
  .wrap p {
    color: var(--ink-soft);
    max-width: 46ch;
    margin-inline: auto;
    margin-bottom: 1.6rem;
  }
</style>
