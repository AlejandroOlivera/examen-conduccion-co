---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
---

<BaseLayout title="Restablecer contrasena · Taller B1" noindex={true}>
  <SiteHeader slot="header" backHref="/recuperar" />

  <section class="container reset" data-accent="azul">
    <div class="reset__intro">
      <h1 class="reset__title">Nueva contrasena</h1>
      <p class="reset__lead">Ingresa la contrasena que queres usar de ahora en adelante.</p>
    </div>

    <div class="card reset__card">
      <div data-reset-invalid hidden>
        Enlace invalido o expirado.
        <a href="/recuperar">Pedi uno nuevo</a>.
      </div>

      <form class="stack" data-reset-form novalidate>
        <div class="field">
          <label class="field__label" for="reset-password">Nueva contrasena</label>
          <input
            class="input"
            id="reset-password"
            name="password"
            type="password"
            autocomplete="new-password"
            required
            minlength="6"
            placeholder="Minimo 6 caracteres"
          />
        </div>

        <div class="field">
          <label class="field__label" for="reset-confirm">Confirmar contrasena</label>
          <input
            class="input"
            id="reset-confirm"
            name="confirm"
            type="password"
            autocomplete="new-password"
            required
            placeholder="Repeti la contrasena"
          />
        </div>

        <p class="alert alert--error" data-reset-error role="alert" hidden></p>

        <button class="btn reset__submit" type="submit">
          <span>Guardar contrasena</span>
          <span class="spinner" aria-hidden="true" hidden></span>
        </button>
      </form>
    </div>
  </section>

  <SiteFooter slot="footer" />
</BaseLayout>

<script>
  import { setupResetForm } from '../scripts/auth';
  document.addEventListener('astro:page-load', setupResetForm);
</script>

<style>
  .reset {
    max-width: 420px;
    padding-block: clamp(2rem, 6vw, 4rem);
  }
  .reset__intro {
    text-align: center;
    margin-bottom: var(--space-5);
  }
  .reset__title {
    font-size: var(--text-3xl);
    margin: 0 0 var(--space-3);
  }
  .reset__lead {
    color: var(--ink-soft);
    margin: 0;
  }
  .reset__card {
    padding: clamp(1.25rem, 4vw, 2rem);
  }
  .reset__submit {
    width: 100%;
    margin-top: var(--space-2);
  }
  [data-reset-invalid] {
    color: var(--ink-soft);
    font-size: var(--text-sm);
    text-align: center;
    padding: var(--space-4) 0;
  }
  [data-reset-invalid] a {
    color: var(--accent);
    text-decoration: underline;
  }
</style>
