---
import { ClientRouter } from 'astro:transitions';
// Fuentes self-hosted (sin dependencia de Google Fonts): Overpass variable
// para el cuerpo y Barlow Semi Condensed (600/700/800) para titulares.
// Se importa el .css explicito (eje de peso vertical) para que coincida con
// la declaracion de tipos '*.css' de Vite bajo TypeScript estricto.
import '@fontsource-variable/overpass/wght.css';
import '@fontsource/barlow-semi-condensed/600.css';
import '@fontsource/barlow-semi-condensed/700.css';
import '@fontsource/barlow-semi-condensed/800.css';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  /** Ruta de la imagen para compartir (relativa al sitio). */
  ogImage?: string;
  /** Texto alternativo de la imagen para compartir. */
  ogImageAlt?: string;
  /** Si es true, marca la pagina como no indexable (p. ej. el 404). */
  noindex?: boolean;
  /** Uno o varios objetos JSON-LD a inyectar como datos estructurados. */
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title,
  description = 'Taller interactivo para preparar el examen teorico de conduccion (Licencia B1) en Colombia, segun la normativa vigente.',
  ogImage = '/og.png',
  ogImageAlt = 'Taller B1 — Examen teorico de conduccion (Licencia B1) en Colombia',
  noindex = false,
  jsonLd,
} = Astro.props;

// Astro.site se define en astro.config.mjs; con eso construimos URLs absolutas
// para canonical y Open Graph (necesarias para previews al compartir).
const canonical = new URL(Astro.url.pathname, Astro.site);
const ogImageUrl = new URL(ogImage, Astro.site);

// Normaliza el JSON-LD a lista para renderizar un <script> por objeto.
const jsonLdItems = jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [];

// Serializa escapando el signo "menor que" (charCode 60) como secuencia
// unicode para que ningun valor pueda cerrar el script. Mismo criterio que
// el payload del quiz; se evita el caracter literal porque rompe el escaner
// de dependencias de Vite en dev.
const ldJson = (obj: Record<string, unknown>) =>
  JSON.stringify(obj)
    .split(String.fromCharCode(60))
    .join(String.fromCharCode(92) + 'u003c');
---

<!doctype html>
<html lang="es-CO">
  <head>
    <meta charset="UTF-8" />
    <!-- viewport-fit=cover: la pagina cubre las safe-areas de iOS (notch y home
         indicator); el fondo asfalto las pinta y abajo se compensa con padding
         env(safe-area-inset-*). Evita la barra blanca del home indicator. -->
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <!-- Tema: render-blocking y antes del primer paint (anti-FOUC). Externo
         (no inline) para mantener una CSP estricta con script-src 'self'.
         is:inline deja la etiqueta tal cual (Astro no la empaqueta). -->
    <script is:inline src="/theme.js"></script>

    <link rel="manifest" href="/manifest.webmanifest" />
    <link rel="apple-touch-icon" href="/icons/icon-192.png" />
    <script is:inline src="/sw-register.js"></script>

    <!-- Scripts render-blocking propios de cada pagina (anti-FOUC). La home
         inyecta aqui el selector de categoria para fijar data-categoria en
         <html> antes del primer paint, igual que el tema. -->
    <slot name="head" />

    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, follow" />}
    <meta name="color-scheme" content="light dark" />
    <meta name="theme-color" content="#1c2024" />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph (WhatsApp, Facebook, LinkedIn) -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Taller B1" />
    <meta property="og:locale" content="es_CO" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:alt" content={ogImageAlt} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content={ogImageAlt} />

    <!-- Datos estructurados (JSON-LD). Bloques de tipo no-JS: el navegador no
         los ejecuta, por eso la CSP script-src 'self' no los bloquea. -->
    {
      jsonLdItems.map((item) => (
        <script type="application/ld+json" is:inline set:html={ldJson(item)} />
      ))
    }

    <title>{title}</title>
    <ClientRouter />
  </head>
  <body>
    <a href="#contenido" class="skip-link">Saltar al contenido</a>
    <slot name="header" />
    <main id="contenido">
      <slot />
    </main>
    <slot name="footer" />

    <style>
      .skip-link {
        position: absolute;
        left: -999px;
        top: 0;
        background: var(--asphalt);
        color: #fff;
        padding: 0.6rem 1rem;
        border-radius: 0 0 8px 0;
        z-index: 50;
      }
      .skip-link:focus {
        left: 0;
      }
      main {
        min-height: 60vh;
      }
    </style>
  </body>
</html>
